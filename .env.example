# Template for every service's environment variables.
# Copy the relevant block into that service's own .env file (never commit those).
#
# Local .env locations:
#   backend/express-service/.env   Express block
#   backend/.env                   FastAPI block
#   frontend/.env                  Frontend block

# ─── Express service (backend/express-service/.env) ──────────────────────────
PORT=5000
DATABASE_URL=
# Must be IDENTICAL to the FastAPI JWT_SECRET below. Express signs the tokens
# that FastAPI verifies; a mismatch means every AI round fails with a 401.
JWT_SECRET=
EMAIL_USER=
EMAIL_PASS=
# COMMA-SEPARATED list of allowed browser origins. In production, your Vercel URL.
CLIENT_URL=http://localhost:5173,http://localhost:5174
# Optional regex to also allow Vercel's per-commit preview URLs.
# CLIENT_ORIGIN_REGEX=^https://.*\.vercel\.app$
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
GOOGLE_CLIENT_ID=
# Where the FastAPI service lives. In production: https://truehire-ai.onrender.com
FASTAPI_URL=http://localhost:8000

# ─── FastAPI AI service (backend/.env) ───────────────────────────────────────
GEMINI_API_KEY=
GITHUB_TOKEN=
# Same value as the Express JWT_SECRET above.
# JWT_SECRET=
# Set to "production" on Render. Disables reading the JWT secret off disk from
# ../express-service/.env, and makes the service refuse to boot without a real
# JWT_SECRET instead of falling back to a public one.
ENVIRONMENT=development
# COMMA-SEPARATED allowed origins. The browser calls this service DIRECTLY for
# the Technical/HR rounds, so your Vercel URL must be listed here too.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
# ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app

# ─── Frontend (frontend/.env) ────────────────────────────────────────────────
# WARNING: VITE_* values are baked into the public bundle at build time and are
# readable by anyone. Never put a secret here. Changing one needs a redeploy.
VITE_API_URL=http://localhost:5000
VITE_GOOGLE_CLIENT_ID=
VITE_FASTAPI_URL=http://localhost:8000