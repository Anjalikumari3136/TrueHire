generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(CANDIDATE)
  profileImage String?
  phone        String?
  location     String?
  currentRole  String?
  experience   Int?
  targetRole   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  resume       Resume?
}

model Resume {
  id         String   @id @default(cuid())
  userId     String   @unique
  resumeName String
  resumeUrl  String
  fileSize   Int
  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PendingUser {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  hashedPassword String
  role           Role     @default(CANDIDATE)
  phone          String?
  location       String?
  currentRole    String?
  experience     Int?
  targetRole     String?
  otp            String
  otpExpiry      DateTime
  createdAt      DateTime @default(now())
}

model PasswordResetOTP {
  id        String   @id @default(uuid())
  email     String   @unique
  otp       String
  otpExpiry DateTime
  createdAt DateTime @default(now())
}

enum Role {
  CANDIDATE
  RECRUITER
  ADMIN
}
