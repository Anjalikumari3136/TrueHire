generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String            @id @default(cuid())
  name         String
  email        String            @unique
  password     String
  role         Role              @default(CANDIDATE)
  profileImage String?
  phone        String?
  location     String?
  currentRole  String?
  experience   Int?
  targetRole   String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  resume       Resume?
  reports      InterviewReport[]
}

model Resume {
  id         String   @id @default(cuid())
  userId     String   @unique
  resumeName String
  resumeUrl  String
  fileSize   Int
  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// One row per completed interview session. Never overwritten — a new interview
// (e.g. after a fresh résumé upload) creates a new row with an incremented
// reportVersion, so full report history is preserved.
model InterviewReport {
  id                String    @id @default(cuid())
  userId            String
  interviewId       String    @unique
  resumeName        String?
  resumeSnapshotUrl String? // storage path of the résumé used for this interview (session boundary)
  reportJson        Json
  overallScore      Float?
  completedRounds   String[]  @default([])
  reportPdfPath     String? // storage path of the generated PDF (null if PDF generation failed)
  reportGeneratedAt DateTime  @default(now())
  reportEmailSent   Boolean   @default(false)
  reportEmailSentAt DateTime?
  reportVersion     Int       @default(1)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PendingUser {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  hashedPassword String
  role           Role     @default(CANDIDATE)
  phone          String?
  location       String?
  currentRole    String?
  experience     Int?
  targetRole     String?
  otp            String
  otpExpiry      DateTime
  createdAt      DateTime @default(now())
}

model PasswordResetOTP {
  id        String   @id @default(uuid())
  email     String   @unique
  otp       String
  otpExpiry DateTime
  createdAt DateTime @default(now())
}

enum Role {
  CANDIDATE
  RECRUITER
  ADMIN
}
